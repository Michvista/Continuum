# Neon Postgres connection string (get from neon.tech project dashboard)
DATABASE_URL="postgresql://user:password@host.neon.tech/continuum?sslmode=require"

# Where the Python cognee-service is running
COGNEE_WRAPPER_URL="http://localhost:8088"

# Port for this Express API
PORT=4000

# Optional: Cloudinary for storing scanned-document / photo / voice-note proof attachments
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Groq — used for voice-note transcription (Whisper)
GROQ_API_KEY=

# Google Gemini — used for scanned-document OCR (Gemini 2.5 Flash, multimodal)
GEMINI_API_KEY=
