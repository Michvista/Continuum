# ── Option A: Cognee Pro / Cloud (use this if you were given a Cognee Cloud
#    API key, e.g. for a hackathon) ──────────────────────────────────────
# If this is set, the service uses cognee.serve()/remember()/recall() against
# Cognee's hosted infrastructure and you do NOT need LLM_API_KEY below.
# Use the URL and key Cognee gave you for your cloud tenant.
COGNEE_API_KEY=
COGNEE_SERVICE_URL=https://api.cognee.ai

# ── Option B: self-hosted (used only if COGNEE_API_KEY is empty) ───
# Required by cognee for entity/relationship extraction during cognify()
LLM_API_KEY=your-openai-api-key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Port for this FastAPI service
COGNEE_SERVICE_PORT=8088
